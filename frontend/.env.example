# URL backend — kosongkan di dev jika VITE_USE_PROXY=true (pakai proxy Vite)
VITE_API_URL=https://tv.mqlspot.my.id
VITE_USE_PROXY=true

# Harus sama dengan ADMIN_API_KEY di backend/.env
VITE_ADMIN_API_KEY=your-admin-api-key

# Dev server — bind ke jaringan LAN
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_PUBLIC_URL=https://tv.mqlspot.my.id
