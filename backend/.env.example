# PostgreSQL — user harus punya hak CREATE di schema public
DATABASE_URL=postgresql://mqltv:password@localhost:5432/mqltv

# JWT
JWT_SECRET=ubah-dengan-string-acak-panjang
JWT_REFRESH_SECRET=ubah-dengan-string-acak-panjang-lain

# CORS — tambahkan URL frontend admin (pisahkan koma)
ALLOWED_ORIGINS=http://localhost:5173,https://tv.mqlspot.my.id

# Redis (rate limit & cache)
REDIS_URL=redis://127.0.0.1:6379

# Admin panel (header X-Admin-Key) — harus sama dengan VITE_ADMIN_API_KEY di frontend
ADMIN_API_KEY=your-admin-api-key

# Stream signing (opsional, untuk proxy masa depan)
STREAM_SECRET=your-stream-secret

# Server
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=https://tv.mqlspot.my.id

# EPG (XMLTV Indonesia)
EPG_URL=https://epg.pw/xmltv/epg_ID.xml

# Midtrans (opsional)
MIDTRANS_SERVER_KEY=
